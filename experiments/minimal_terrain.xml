<mujoco model="riverbed">
  <compiler angle="radian" autolimits="true"/>
  
  <option timestep="0.01" gravity="0 0 -9.81" iterations="50" tolerance="1e-10"/>
  
  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4"/>
    <map znear="0.01"/>
  </visual>
  
  <asset>
    <!-- Heightfield: 64x64 grid, 32x32 meters, max height 2m -->
    <hfield name="riverbed" nrow="64" ncol="64" size="32 32 2 0.1"/>
    
    <!-- Materials for better visualization -->
    <material name="ground_low" rgba="0.2 0.4 0.2 1" specular="0.2"/>
    <material name="ground_medium" rgba="0.5 0.4 0.3 1" specular="0.3"/>
    <material name="ground_high" rgba="0.6 0.5 0.4 1" specular="0.4"/>
  </asset>
  
  <worldbody>
    <!-- Better lighting -->
    <light name="light1" pos="0 0 20" dir="0 0 -1" directional="true" castshadow="true"/>
    <light name="light2" pos="10 10 10" dir="-1 -1 -1" castshadow="true"/>
    
    <!-- Terrain geom with material that will be colored by height -->
    <geom name="ground" type="hfield" hfield="riverbed" material="ground_medium" 
          friction="1.5 0.8 0.5" rgba="0.6 0.5 0.4 1"/>
    
    <!-- Reference grid to show scale -->
    <geom name="grid" type="plane" size="16 16 0.01" rgba="1 1 1 0.1" 
          contype="0" conaffinity="0" pos="0 0 0.01"/>
  </worldbody>
</mujoco>